import sys
sys.path.insert(0, "tools")
from royalty_calc import compute_royalty, compute_interest, check_minimum_guarantee

# Case data from techloom_v_dataforge.md
quarters = [
    {"quarter": "Q1 2025", "end_date": "03/31/2025", "net_revenue": 5_500_000, "royalty_paid": 350_000},
    {"quarter": "Q2 2025", "end_date": "06/30/2025", "net_revenue": 6_200_000, "royalty_paid": 380_000},
    {"quarter": "Q3 2025", "end_date": "09/30/2025", "net_revenue": 7_100_000, "royalty_paid": 400_000},
    {"quarter": "Q4 2025", "end_date": "12/31/2025", "net_revenue": 7_800_000, "royalty_paid": 420_000}
]

# Contract terms
royalty_rate = 0.08  # 8%
minimum_annual_guarantee = 1_200_000
interest_rate = 0.10  # 10% per annum
payment_due_days = 30  # Payment due within 30 days of quarter end

print("TechLoom v. DataForge - Royalty Analysis")
print("=" * 50)

# Calculate royalties owed vs paid per quarter
total_revenue = 0
total_owed = 0
total_paid = 0
total_underpayment = 0
quarterly_details = []

for q in quarters:
    revenue = q["net_revenue"]
    paid = q["royalty_paid"]
    owed = compute_royalty(revenue, royalty_rate)
    underpayment = owed - paid
    
    total_revenue += revenue
    total_owed += owed
    total_paid += paid
    total_underpayment += underpayment
    
    quarterly_details.append({
        "quarter": q["quarter"],
        "end_date": q["end_date"],
        "revenue": revenue,
        "owed": owed,
        "paid": paid,
        "underpayment": underpayment
    })
    
    print(f"\n{q['quarter']}:")
    print(f"  Net Revenue: ${revenue:,.0f}")
    print(f"  Royalty Owed (8%): ${owed:,.0f}")
    print(f"  Royalty Paid: ${paid:,.0f}")
    print(f"  Underpayment: ${underpayment:,.0f}")

print(f"\nANNUAL TOTALS:")
print(f"Total Net Revenue: ${total_revenue:,.0f}")
print(f"Total Royalty Owed: ${total_owed:,.0f}")
print(f"Total Royalty Paid: ${total_paid:,.0f}")
print(f"Total Underpayment: ${total_underpayment:,.0f}")

# Check minimum annual guarantee
guarantee_check = check_minimum_guarantee(total_owed, minimum_annual_guarantee)
print(f"\nMinimum Annual Guarantee: ${minimum_annual_guarantee:,.0f}")
if guarantee_check["exceeded"]:
    print(f"Guarantee exceeded by: ${guarantee_check['surplus']:,.0f}")
else:
    print(f"Guarantee shortfall: ${guarantee_check['shortfall']:,.0f}")

# Calculate interest on underpayments
# Payment is due 30 days after quarter end, interest accrues from that due date
print(f"\nINTEREST CALCULATIONS:")
total_interest = 0

for q in quarterly_details:
    if q["underpayment"] > 0:
        # Calculate due date (30 days after quarter end)
        quarter_end = q["end_date"]
        if quarter_end == "03/31/2025":
            due_date = "04/30/2025"
        elif quarter_end == "06/30/2025":
            due_date = "07/30/2025"
        elif quarter_end == "09/30/2025":
            due_date = "10/30/2025"
        elif quarter_end == "12/31/2025":
            due_date = "01/30/2026"
        
        # Interest accrues from due date to 12/31/2025 (end of dispute period)
        # For Q4, we'll calculate to a reasonable assessment date
        to_date = "12/31/2025" if quarter_end != "12/31/2025" else "03/31/2026"
        
        interest = compute_interest(q["underpayment"], interest_rate, due_date, to_date)
        total_interest += interest
        
        print(f"{q['quarter']} underpayment interest:")
        print(f"  Principal: ${q['underpayment']:,.0f}")
        print(f"  From: {due_date} to {to_date}")
        print(f"  Interest: ${interest:,.0f}")

print(f"\nTotal Interest on Underpayments: ${total_interest:,.0f}")
print(f"TOTAL DAMAGES: ${total_underpayment + total_interest:,.0f}")

# Material breach analysis
print(f"\nBREACH ANALYSIS:")
underpayment_percentage = (total_underpayment / total_owed) * 100
print(f"Underpayment as % of total owed: {underpayment_percentage:.1f}%")
print(f"Underpayment amount: ${total_underpayment:,.0f}")

if underpayment_percentage > 10 or total_underpayment > 100_000:
    print("ASSESSMENT: Material breach - systematic underpayment")
else:
    print("ASSESSMENT: Minor breach")
EOF

