# Calculate addressable market for NovaTech (mid-market segment)
mid_market_share = 0.45
addressable_market = scm_market_size * mid_market_share

# Print results
print(f'SCM Market Size: ${scm_market_size:.2f} billion')
print(f'Addressable Market (Mid-Market): ${addressable_market:.2f} billion')

# Calculate TAM/SAM/SOM
# TAM = Total Addressable Market = $15.3B * 0.12 * 0.45 = $1.04B
# SAM = Serviceable Addressable Market = $1.04B (same as TAM in this case)
# SOM = Serviceable Obtainable Market = $1.04B * 0.02 (Year 1) = $20.8M

tam = 15.3 * 0.12 * 0.45
sam = tam
som_year1 = tam * 0.02
som_year3 = tam * 0.05
som_year5 = tam * 0.08

print(f'TAM: ${tam:.2f} billion')
print(f'SAM: ${sam:.2f} billion')
print(f'SOM Year 1: ${som_year1:.2f} billion')
print(f'SOM Year 3: ${som_year3:.2f} billion')
print(f'SOM Year 5: ${som_year5:.2f} billion')
"

