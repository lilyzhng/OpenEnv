import sys
sys.path.insert(0, "tools")
from xirr_tool import xirr, xnpv

# Original cash flow data
dates = [
    "03/03/2024",  # Initial capex
    "12/31/2024",  # Period 1
    "06/30/2025",  # Period 2
    "12/31/2025",  # Period 3
    "06/30/2026",  # Period 4
    "08/12/2026",  # Maintenance expense
    "12/31/2026",  # Period 5
    "06/30/2027",  # Period 6
    "12/31/2027",  # Period 7
    "06/30/2028",  # Period 8
    "12/31/2028"   # Sale value
]

cash_flows = [
    -50.0,  # Initial capex
    7.5,    # Period 1 revenue
    8.25,   # Period 2 revenue
    9.0,    # Period 3 revenue
    9.75,   # Period 4 revenue
    -10.0,  # Maintenance expense
    10.5,   # Period 5 revenue
    11.25,  # Period 6 revenue
    12.0,   # Period 7 revenue
    12.75,  # Period 8 revenue
    10.0    # Sale value
]

# 1. Calculate IRR and MOIC
irr = xirr(dates, cash_flows)
total_inflows = sum([cf for cf in cash_flows if cf > 0])
total_outflows = abs(sum([cf for cf in cash_flows if cf < 0]))
moic = total_inflows / total_outflows

print(f"1. IRR: {irr*100:.1f}%")
print(f"   MOIC: {moic:.1f}x")

# 2. NPV at 10%, 15%, and 20%
npv_10 = xnpv(0.10, dates, cash_flows)
npv_15 = xnpv(0.15, dates, cash_flows)
npv_20 = xnpv(0.20, dates, cash_flows)

print(f"\n2. NPV at 10%: ${npv_10:.1f}MM")
print(f"   NPV at 15%: ${npv_15:.1f}MM")
print(f"   NPV at 20%: ${npv_20:.1f}MM")

# 3. Required Sale Value to achieve 15%, 20%, and 25% IRR
def find_required_sale_value(target_irr):
    # Binary search for sale value
    low, high = 0, 100
    tolerance = 0.001
    
    for _ in range(100):  # max iterations
        mid = (low + high) / 2
        test_flows = cash_flows[:-1] + [mid]  # Replace last cash flow (sale value)
        test_irr = xirr(dates, test_flows)
        
        if abs(test_irr - target_irr) < tolerance:
            return mid
        elif test_irr < target_irr:
            low = mid
        else:
            high = mid
    return mid

sale_15 = find_required_sale_value(0.15)
sale_20 = find_required_sale_value(0.20)
sale_25 = find_required_sale_value(0.25)

print(f"\n3. Required Sale Value for 15% IRR: ${sale_15:.1f}MM")
print(f"   Required Sale Value for 20% IRR: ${sale_20:.1f}MM")
print(f"   Required Sale Value for 25% IRR: ${sale_25:.1f}MM")

# 4. Required Unit Profit Price to achieve 15%, 20%, and 25% IRR
def find_required_unit_price(target_irr):
    # Binary search for unit profit price
    low, high = 50, 500
    tolerance = 0.001
    
    for _ in range(100):  # max iterations
        mid = (low + high) / 2
        
        # Recalculate cash flows with new unit price
        # Units: 50k, 55k, 60k, 65k, 70k, 75k, 80k, 85k
        units = [50000, 55000, 60000, 65000, 70000, 75000, 80000, 85000]
        new_revenues = [u * mid / 1000000 for u in units]  # Convert to millions
        
        test_flows = [
            -50.0,  # Initial capex
            new_revenues[0],  # Period 1
            new_revenues[1],  # Period 2
            new_revenues[2],  # Period 3
            new_revenues[3],  # Period 4
            -10.0,  # Maintenance
            new_revenues[4],  # Period 5
            new_revenues[5],  # Period 6
            new_revenues[6],  # Period 7
            new_revenues[7],  # Period 8
            10.0    # Sale value
        ]
        
        test_irr = xirr(dates, test_flows)
        
        if abs(test_irr - target_irr) < tolerance:
            return mid
        elif test_irr < target_irr:
            low = mid
        else:
            high = mid
    return mid

price_15 = find_required_unit_price(0.15)
price_20 = find_required_unit_price(0.20)
price_25 = find_required_unit_price(0.25)

print(f"\n4. Required Unit Profit Price for 15% IRR: ${price_15:.2f}")
