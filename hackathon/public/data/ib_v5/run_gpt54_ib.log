from datetime import datetime
from math import isfinite

dates = [
    "03/03/2024",
    "12/31/2024",
    "06/30/2025",
    "12/31/2025",
    "06/30/2026",
    "08/12/2026",
    "12/31/2026",
    "06/30/2027",
    "12/31/2027",
    "06/30/2028",
    "12/31/2028",
]
cfs = [-50.0, 7.5, 8.25, 9.0, 9.75, -10.0, 10.5, 11.25, 12.0, 12.75, 10.0]
dt = [datetime.strptime(d, "%m/%d/%Y") for d in dates]

def xnpv(rate, cashflows):
    t0 = dt[0]
    total = 0.0
    for d, cf in zip(dt, cashflows):
        total += cf / ((1 + rate) ** (((d - t0).days) / 365.0))
    return total

def xirr(cashflows, low=-0.9999, high=10.0):
    fl = xnpv(low, cashflows)
    fh = xnpv(high, cashflows)
    while fl * fh > 0 and high < 1e6:
        high *= 2
        fh = xnpv(high, cashflows)
    for _ in range(300):
        mid = (low + high) / 2
        fm = xnpv(mid, cashflows)
        if abs(fm) < 1e-12:
            return mid
        if fl * fm <= 0:
            high = mid
            fh = fm
        else:
            low = mid
            fl = fm
    return (low + high) / 2

irr = xirr(cfs)
inflows = sum(cf for cf in cfs if cf > 0)
outflows = -sum(cf for cf in cfs if cf < 0)
moic = inflows / outflows

npv10 = xnpv(0.10, cfs)
npv15 = xnpv(0.15, cfs)
npv20 = xnpv(0.20, cfs)

sale_idx = len(cfs) - 1
sale_base = cfs[sale_idx]

def required_sale_value(target):
    t0 = dt[0]
    sale_t = ((dt[sale_idx] - t0).days) / 365.0
    pv_other = sum(cf / ((1+target)**(((d-t0).days)/365.0)) for i,(d,cf) in enumerate(zip(dt,cfs)) if i != sale_idx)
    x = -pv_other * ((1+target) ** sale_t)
    return x

unit_counts = [50000,55000,60000,65000,70000,75000,80000,85000]
rev_indices = [1,2,3,4,6,7,8,9]

def required_unit_profit(target):
    t0 = dt[0]
    pv_fixed = cfs[0]/((1+target)**0) + cfs[5]/((1+target)**(((dt[5]-t0).days)/365.0)) + cfs[10]/((1+target)**(((dt[10]-t0).days)/365.0))
    coeff = 0.0
    for units, idx in zip(unit_counts, rev_indices):
        coeff += (units/1_000_000.0) / ((1+target)**(((dt[idx]-t0).days)/365.0))
    p = -pv_fixed / coeff
    return p

sale15 = required_sale_value(0.15)
sale20 = required_sale_value(0.20)
sale25 = required_sale_value(0.25)

upp15 = required_unit_profit(0.15)
upp20 = required_unit_profit(0.20)
upp25 = required_unit_profit(0.25)

with open("analysis.txt", "w") as f:
    f.write(f"KatNip Co. Analysis\n")
    f.write(f"IRR: {irr*100:.1f}%\n")
    f.write(f"MOIC: {moic:.1f}x\n")
    f.write(f"NPV @ 10%: ${npv10:.1f}MM\n")
    f.write(f"NPV @ 15%: ${npv15:.1f}MM\n")
    f.write(f"NPV @ 20%: ${npv20:.1f}MM\n")
    f.write(f"Required Sale Value for 15% IRR: ${sale15:.1f}MM\n")
    f.write(f"Required Sale Value for 20% IRR: ${sale20:.1f}MM\n")
    f.write(f"Required Sale Value for 25% IRR: ${sale25:.1f}MM\n")
    f.write(f"Required Unit Profit Price for 15% IRR: ${upp15:.2f}\n")
    f.write(f"Required Unit Profit Price for 20% IRR: ${upp20:.2f}\n")
    f.write(f"Required Unit Profit Price for 25% IRR: ${upp25:.2f}\n")
print(open("analysis.txt").read())
