import sys
sys.path.insert(0, 'tools')
from royalty_calc import compute_royalty, compute_interest, check_minimum_guarantee

# Quarterly data
quarters = [
    {'quarter': 'Q1 2025', 'end_date': '03/31/2025', 'revenue': 5500000, 'paid': 350000},
    {'quarter': 'Q2 2025', 'end_date': '06/30/2025', 'revenue': 6200000, 'paid': 380000},
    {'quarter': 'Q3 2025', 'end_date': '09/30/2025', 'revenue': 7100000, 'paid': 400000},
    {'quarter': 'Q4 2025', 'end_date': '12/31/2025', 'revenue': 7800000, 'paid': 420000},
]

# Payment due dates (30 days after quarter end)
due_dates = [
    '04/30/2025',
    '07/30/2025', 
    '10/30/2025',
    '01/30/2026'
]

# Calculate for each quarter
results = []
total_owed = 0
total_paid = 0

for i, q in enumerate(quarters):
    owed = compute_royalty(q['revenue'], 0.08)
    shortfall = owed - q['paid']
    total_owed += owed
    total_paid += q['paid']
    
    # Calculate interest (only for quarters that have passed)
    interest = 0
    if i < 3:  # Q1, Q2, Q3 have passed
        interest = compute_interest(shortfall, 0.10, due_dates[i], '12/31/2025')
    
    results.append({
        'quarter': q['quarter'],
        'owed': owed,
        'paid': q['paid'],
        'shortfall': shortfall,
        'interest': interest
    })

# Check minimum guarantee
min_guarantee = 1200000
min_check = check_minimum_guarantee(total_owed, min_guarantee)

# Write to memo.txt
with open('memo.txt', 'w') as f:
    f.write('TechLoom Inc. v. DataForge Corp. - Legal Memorandum\n')
    f.write('=' * 50 + '\n\n')
    
    f.write('1. Quarterly Royalty Analysis\n')
    f.write('----------------------------\n')
    for r in results:
        f.write(f'{r[\"quarter\"]}:\n')
        f.write(f'  - Net Revenue: ${r[\"owed\"]:,.0f}\n')
        f.write(f'  - Paid: ${r[\"paid\"]:,.0f}\n')
        f.write(f'  - Shortfall: ${r[\"shortfall\"]:,.0f}\n')
        f.write(f'  - Interest: ${r[\"interest\"]:,.0f}\n\n')
    
    f.write('2. Total Damages\n')
    f.write('----------------\n')
    total_shortfall = sum(r['shortfall'] for r in results)
    total_interest = sum(r['interest'] for r in results)
    f.write(f'Total Shortfall: ${total_shortfall:,.0f}\n')
    f.write(f'Total Interest: ${total_interest:,.0f}\n')
    f.write(f'Total Damages: ${total_shortfall + total_interest:,.0f}\n\n')
    
    f.write('3. Minimum Guarantee Analysis\n')
    f.write('----------------------------\n')
    if min_check['exceeded']:
        f.write(f'Minimum guarantee of ${min_guarantee:,.0f} exceeded by ${min_check[\"surplus\"]:,.0f}\n')
    else:
        f.write(f'Minimum guarantee of ${min_guarantee:,.0f} not met. Shortfall: ${min_check[\"shortfall\"]:,.0f}\n\n')
    
    f.write('4. Breach Characterization\n')
    f.write('--------------------------\n')
    if total_shortfall > 0:
        f.write('Material breach: Systematic underpayment of royalties throughout 2025.\n')
        f.write('DataForge failed to meet its contractual obligations and minimum guarantee.\n\n')
    else:
        f.write('No material breach detected.\n\n')
    
    f.write('5. Recommended Remedies\n')
    f.write('-----------------------\n')
    f.write('a) Payment of total damages (${:,.0f})\n'.format(total_shortfall + total_interest))
    f.write('b) Declaration of material breach\n')
    f.write('c) Termination of license agreement\n')
    f.write('d) Payment of additional interest on outstanding amounts\n')
    f.write('e) Audit rights to verify future revenue reporting\n')
"

