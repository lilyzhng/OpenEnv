<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Hourglass</title></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#e8dcc8;">
<svg id="art" viewBox="0 0 300 300" width="300" height="300" xmlns="http://www.w3.org/2000/svg"></svg>
<script src="https://unpkg.com/roughjs/bundled/rough.js"></script>
<script>
const INK = '#1a1a1a';
const svg = document.getElementById('art');
const rc = rough.svg(svg);

const outlineOpts = { stroke: INK, strokeWidth: 3.5, fill: 'none', roughness: 0.8 };
svg.appendChild(rc.polygon([[100, 50], [200, 50], [150, 150]], outlineOpts));
svg.appendChild(rc.polygon([[100, 250], [200, 250], [150, 150]], outlineOpts));

const sandOpts = { stroke: INK, strokeWidth: 1.5, roughness: 1.2 };
svg.appendChild(rc.circle(150, 100, 30, sandOpts));
svg.appendChild(rc.circle(150, 200, 30, sandOpts));

const standOpts = { stroke: INK, strokeWidth: 2.5, roughness: 0.6 };
svg.appendChild(rc.rectangle(140, 30, 20, 20, standOpts));
svg.appendChild(rc.rectangle(140, 250, 20, 20, standOpts));
</script>
</body>
</html>
EOF

