<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Draw: HOURGLASS</title></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#e8dcc8;">
<svg id="art" viewBox="0 0 300 300" width="300" height="300" xmlns="http://www.w3.org/2000/svg"></svg>
<script src="https://unpkg.com/roughjs/bundled/rough.js"></script>
<script>
const INK = '#1a1a1a';
const WHITE = '#f0ebe0';

const svg = document.getElementById('art');
const rc = rough.svg(svg);

// frame
const frameOpts = { stroke: INK, strokeWidth: 4, fill: 'none', roughness: 0.8 };
svg.appendChild(rc.line(105, 42, 95, 258, frameOpts));
svg.appendChild(rc.line(195, 42, 205, 258, frameOpts));
svg.appendChild(rc.line(98, 38, 202, 38, frameOpts));
svg.appendChild(rc.line(92, 262, 208, 262, frameOpts));

// caps
svg.appendChild(rc.path('M 112 56 A 58 18 0 0 1 188 56', frameOpts));
svg.appendChild(rc.path('M 112 244 A 58 18 0 0 0 188 244', frameOpts));

// glass bulbs
const glassOpts = { stroke: INK, strokeWidth: 3.5, fill: WHITE, fillStyle: 'solid', roughness: 0.7 };
svg.appendChild(rc.polygon([[118, 62], [182, 62], [155, 122], [150, 135], [145, 122]], glassOpts));
svg.appendChild(rc.polygon([[145, 178], [150, 165], [155, 178], [182, 238], [118, 238]], glassOpts));

// neck opening
const detailOpts = { stroke: INK, strokeWidth: 2.5, roughness: 0.8 };
svg.appendChild(rc.line(142, 149, 158, 149, detailOpts));
svg.appendChild(rc.line(144, 154, 156, 154, detailOpts));

// upper sand pile
svg.appendChild(rc.polygon([[126, 96], [174, 96], [160, 114], [140, 114]], {
  stroke: INK, strokeWidth: 2, fill: '#d1b06a', fillStyle: 'hachure', fillWeight: 1.5, roughness: 0.8
}));

// falling sand
svg.appendChild(rc.line(150, 116, 150, 192, {
  stroke: '#d1b06a', strokeWidth: 2.2, roughness: 0.5
}));

// lower sand pile
svg.appendChild(rc.polygon([[128, 226], [172, 226], [150, 188]], {
  stroke: INK, strokeWidth: 2, fill: '#d1b06a', fillStyle: 'hachure', fillWeight: 1.5, roughness: 0.8
}));

// sand dots
svg.appendChild(rc.circle(150, 196, 6, { stroke: INK, strokeWidth: 1.5, fill: '#d1b06a', fillStyle: 'solid', roughness: 0.5 }));
svg.appendChild(rc.circle(146, 202, 4, { stroke: INK, strokeWidth: 1.2, fill: '#d1b06a', fillStyle: 'solid', roughness: 0.5 }));
svg.appendChild(rc.circle(154, 205, 4, { stroke: INK, strokeWidth: 1.2, fill: '#d1b06a', fillStyle: 'solid', roughness: 0.5 }));

// accent spark lines
svg.appendChild(rc.line(72, 86, 58, 72, detailOpts));
svg.appendChild(rc.line(228, 84, 242, 70, detailOpts));
svg.appendChild(rc.line(66, 154, 52, 154, detailOpts));
svg.appendChild(rc.line(234, 154, 248, 154, detailOpts));
</script>
</body>
</html>
EOF

