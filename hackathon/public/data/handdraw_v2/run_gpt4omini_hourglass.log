<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hourglass Illustration</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/roughjs/4.3.1/rough.min.js"></script>
</head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#e8dcc8;">
    <svg id="art" viewBox="0 0 300 400" width="300" height="400" xmlns="http://www.w3.org/2000/svg"></svg>
    <script>
        const INK = "#1a1a1a";
        const svg = document.getElementById("art");
        const rc = rough.svg(svg);
        
        // Draw the hourglass shape
        const outlineOpts = { stroke: INK, strokeWidth: 3.5, fill: "none", roughness: 0.8 };
        svg.appendChild(rc.polygon([[150, 50], [100, 200], [200, 200]], outlineOpts)); // Top triangle
        svg.appendChild(rc.polygon([[100, 200], [150, 350], [200, 200]], outlineOpts)); // Bottom triangle
    </script>
</body>
</html>' > /var/folders/zb/gv9h0w894b92wzw6hwsqc0pr0000gn/T/apex_hd_2_1tchgu/hourglass.html

