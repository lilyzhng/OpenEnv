<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Draw: HOURGLASS</title></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#e8dcc8;">
<svg id="art" viewBox="0 0 300 300" width="300" height="300" xmlns="http://www.w3.org/2000/svg"></svg>
<script src="https://unpkg.com/roughjs/bundled/rough.js"></script>
<!-- Import building blocks from elements/ -->
<script src="elements/triangle.js"></script>
<script src="elements/circle.js"></script>
<script src="elements/rectangle.js"></script>
<script src="elements/line.js"></script>
<script>
const INK = '#1a1a1a';
const svg = document.getElementById('art');
const rc = rough.svg(svg);
const opts = { stroke: INK, strokeWidth: 3.5, fill: 'none', roughness: 0.8 };

// === HOURGLASS ILLUSTRATION ===

// Top bulb of hourglass (inverted triangle)
drawTriangle(rc, svg, 150, 80, 120, 'down', opts);

// Bottom bulb of hourglass (upright triangle)
drawTriangle(rc, svg, 150, 220, 120, 'up', opts);

// Hourglass frame - vertical lines connecting the triangles
drawLine(rc, svg, 90, 120, 90, 180, opts);
drawLine(rc, svg, 210, 120, 210, 180, opts);

// Sand in top bulb (small dots)
drawDot(rc, svg, 130, 90, 4, INK);
drawDot(rc, svg, 160, 95, 3, INK);
drawDot(rc, svg, 145, 105, 3, INK);
drawDot(rc, svg, 170, 110, 4, INK);
drawDot(rc, svg, 125, 110, 3, INK);

// Sand in bottom bulb (more dots)
drawDot(rc, svg, 140, 200, 4, INK);
drawDot(rc, svg, 155, 205, 3, INK);
drawDot(rc, svg, 165, 195, 4, INK);
drawDot(rc, svg, 135, 210, 3, INK);
drawDot(rc, svg, 160, 215, 4, INK);
drawDot(rc, svg, 145, 190, 3, INK);

// Falling sand stream in the middle
drawLine(rc, svg, 150, 140, 150, 160, { stroke: INK, strokeWidth: 2, roughness: 0.6 });

</script>
</body>
</html>
EOF

