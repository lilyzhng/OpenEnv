total_it_spend = 85_000  # $85B in millions
saas_share = 0.18  # 18% of IT spending
scm_share = 0.12  # 12% of B2B SaaS market
mid_market_share = 0.45  # 45% of SCM market

# Unit economics data
acv = 48_000  # $48K annual contract value
cac = 12_000  # $12K customer acquisition cost
lifespan_years = 3.0  # 3 year average customer lifespan

