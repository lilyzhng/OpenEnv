sam = compute_sam(tam, mid_market_share)
som_year_1 = compute_som(sam, year_1_penetration)
som_year_3 = compute_som(sam, year_3_penetration)
som_year_5 = compute_som(sam, year_5_penetration)

# Calculate unit economics
econ = compute_unit_economics(acv, cac, lifespan_years)

print("MARKET SIZING:")
