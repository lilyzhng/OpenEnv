print(f"Year 5 SOM: ${som_year_5:,.1f}MM")
print()
print("UNIT ECONOMICS:")
print(f"LTV: ${econ['ltv']:,.0f}")
print(f"LTV/CAC Ratio: {econ['ltv_cac_ratio']:.1f}x")
