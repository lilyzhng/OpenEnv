print(f'B2B SaaS Market Size: ${b2b_sas_size:.1f} billion')
print(f'SCM Market Size: ${scm_market_size:.1f} billion')
print(f'Addressable SCM Market (Mid-Market): ${addressable_scm:.1f} billion')

# Calculate TAM/SAM/SOM
