# 3. Required Sale Value to achieve 15%, 20%, and 25% IRR
def find_required_sale_value(target_irr):
    # Binary search for the required sale value
    low, high = 0, 100
    for _ in range(100):
        mid = (low + high) / 2
        test_cf = cash_flows[:-1] + [mid]  # Replace last cash flow (sale value)
        test_irr = xirr(dates, test_cf)
        if abs(test_irr - target_irr) < 0.001:
            return mid
        elif test_irr < target_irr:
            low = mid
        else:
            high = mid
    return mid

