    '03/03/2024', '12/31/2024', '06/30/2025', '12/31/2025', '06/30/2026',
    '08/12/2026', '12/31/2026', '06/30/2027', '12/31/2027', '06/30/2028', '12/31/2028'
]
cash_flows = [
    -50.0, 7.5, 8.25, 9.0, 9.75,
    -10.0, 10.5, 11.25, 12.0, 12.75, 10.0
]

irr = xirr(dates, cash_flows)
moic = round(sum(cf for cf in cash_flows if cf > 0) / abs(cash_flows[0]), 1)
npv_10 = xnpv(0.10, dates, cash_flows)
npv_15 = xnpv(0.15, dates, cash_flows)
npv_20 = xnpv(0.20, dates, cash_flows)

def required_sale_value(target_irr):
    x0 = 10.0
    for _ in range(100):
        cfs = cash_flows[:-1] + [x0]
        f = xirr(dates, cfs) - target_irr
        h = 1e-5
        cfs_h = cash_flows[:-1] + [x0 + h]
        f_h = xirr(dates, cfs_h) - target_irr
        dfdx = (f_h - f) / h
        if abs(dfdx) < 1e-10:
            break
        x1 = x0 - f / dfdx
        if abs(x1 - x0) < 1e-6:
            return round(x1, 1)
        x0 = x1
    return round(x0, 1)

sale_15 = required_sale_value(0.15)
sale_20 = required_sale_value(0.20)
sale_25 = required_sale_value(0.25)

def required_unit_profit(target_irr):
    units = [0, 50000, 55000, 60000, 65000, 0, 70000, 75000, 80000, 85000, 0]
    x0 = 150.0
    for _ in range(100):
        cfs = []
        for i, cf in enumerate(cash_flows):
            if i == 0 or i == 5:
                cfs.append(cf)
            elif i == 10:
                cfs.append(10.0)
            else:
                cfs.append(units[i] * x0 / 1e6)
        f = xirr(dates, cfs) - target_irr
        h = 1e-3
        cfs_h = []
        for i, cf in enumerate(cash_flows):
            if i == 0 or i == 5:
                cfs_h.append(cf)
            elif i == 10:
                cfs_h.append(10.0)
            else:
                cfs_h.append(units[i] * (x0 + h) / 1e6)
        f_h = xirr(dates, cfs_h) - target_irr
        dfdx = (f_h - f) / h
        if abs(dfdx) < 1e-10:
            break
        x1 = x0 - f / dfdx
        if abs(x1 - x0) < 1e-6:
            return round(x1, 2)
        x0 = x1
    return round(x0, 2)

unit_15 = required_unit_profit(0.15)
unit_20 = required_unit_profit(0.20)
unit_25 = required_unit_profit(0.25)

with open('analysis.txt', 'w') as f:
    f.write(f'IRR: {irr*100:.1f}%\\n')
    f.write(f'MOIC: {moic}x\\n')
    f.write(f'NPV at 10%: ${npv_10:.1f}MM\\n')
    f.write(f'NPV at 15%: ${npv_15:.1f}MM\\n')
    f.write(f'NPV at 20%: ${npv_20:.1f}MM\\n')
    f.write(f'Required Sale Value for 15% IRR: ${sale_15}MM\\n')
    f.write(f'Required Sale Value for 20% IRR: ${sale_20}MM\\n')
    f.write(f'Required Sale Value for 25% IRR: ${sale_25}MM\\n')
    f.write(f'Required Unit Profit Price for 15% IRR: ${unit_15}\\n')
    f.write(f'Required Unit Profit Price for 20% IRR: ${unit_20}\\n')
    f.write(f'Required Unit Profit Price for 25% IRR: ${unit_25}\\n')
" > katnip_analysis.py

