# Required Sale Value for target IRRs (change last cash flow)
def required_sale_value(target_irr):
    # Copy cash flows and set last value to x, then solve for x where IRR = target_irr
    from scipy.optimize import brentq
    def f(x):
        cfs = cash_flows[:-1] + [x]
        return xirr(dates, cfs) - target_irr
    # Reasonable bounds: 0 to 100
    return round(brentq(f, 0, 100), 1)

sale_15 = required_sale_value(0.15)
sale_20 = required_sale_value(0.20)
sale_25 = required_sale_value(0.25)

# Required unit profit price for target IRRs (change all positive cash flows proportionally)
def required_unit_profit(target_irr):
    from scipy.optimize import brentq
    def f(unit_profit):
        # Recalculate all positive cash flows (except maintenance and capex)
        units = [0, 50000, 55000, 60000, 65000, 0, 70000, 75000, 80000, 85000, 0]
        cfs = []
        for i, cf in enumerate(cash_flows):
            if i == 0 or i == 5:
                cfs.append(cf)
            elif i == 10:
                cfs.append(10.0)
            else:
                cfs.append(units[i] * unit_profit / 1e6)
        return xirr(dates, cfs) - target_irr
    # Reasonable bounds: $0 to $500
    return round(brentq(f, 0, 500), 2)

unit_15 = required_unit_profit(0.15)
unit_20 = required_unit_profit(0.20)
unit_25 = required_unit_profit(0.25)

