        cfs = cash_flows[:-1] + [x0]
        f = xirr(dates, cfs) - target_irr
        # Numerical derivative
        h = 1e-5
        cfs_h = cash_flows[:-1] + [x0 + h]
        f_h = xirr(dates, cfs_h) - target_irr
        dfdx = (f_h - f) / h
        if abs(dfdx) < 1e-10:
            break
        x1 = x0 - f / dfdx
        if abs(x1 - x0) < 1e-6:
            return round(x1, 1)
        x0 = x1
    return round(x0, 1)

sale_15 = required_sale_value(0.15)
