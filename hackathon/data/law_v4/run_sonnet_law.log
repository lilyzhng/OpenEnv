sys.path.insert(0, "tools")
from royalty_calc import compute_royalty, compute_interest, check_minimum_guarantee

# Case data from techloom_v_dataforge.md
quarters = [
    {"quarter": "Q1 2025", "end_date": "03/31/2025", "net_revenue": 5_500_000, "paid": 350_000},
    {"quarter": "Q2 2025", "end_date": "06/30/2025", "net_revenue": 6_200_000, "paid": 380_000},
    {"quarter": "Q3 2025", "end_date": "09/30/2025", "net_revenue": 7_100_000, "paid": 400_000},
    {"quarter": "Q4 2025", "end_date": "12/31/2025", "net_revenue": 7_800_000, "paid": 420_000},
]

# Contract terms
royalty_rate = 0.08  # 8%
minimum_annual_guarantee = 1_200_000
interest_rate = 0.10  # 10% per annum
payment_due_days = 30  # within 30 days of quarter end

print("TechLoom v. DataForge - Royalty Analysis")
print("=" * 50)

# Calculate royalties owed vs paid for each quarter
total_revenue = 0
total_owed = 0
total_paid = 0
total_underpayment = 0
quarterly_details = []

for q in quarters:
    revenue = q["net_revenue"]
    paid = q["paid"]
    owed = compute_royalty(revenue, royalty_rate)
    underpayment = owed - paid
    
    total_revenue += revenue
    total_owed += owed
    total_paid += paid
    total_underpayment += underpayment
    
    quarterly_details.append({
        "quarter": q["quarter"],
        "end_date": q["end_date"],
        "revenue": revenue,
        "owed": owed,
        "paid": paid,
        "underpayment": underpayment
    })
    
    print(f"\n{q['quarter']}:")
    print(f"  Net Revenue: ${revenue:,}")
    print(f"  Royalty Owed (8%): ${owed:,}")
    print(f"  Royalty Paid: ${paid:,}")
    print(f"  Underpayment: ${underpayment:,}")

print(f"\nANNUAL TOTALS:")
print(f"Total Net Revenue: ${total_revenue:,}")
print(f"Total Royalty Owed: ${total_owed:,}")
print(f"Total Royalty Paid: ${total_paid:,}")
print(f"Total Underpayment: ${total_underpayment:,}")

# Check minimum annual guarantee
guarantee_check = check_minimum_guarantee(total_owed, minimum_annual_guarantee)
print(f"\nMinimum Annual Guarantee: ${minimum_annual_guarantee:,}")
if guarantee_check["exceeded"]:
    print(f"Guarantee exceeded by: ${guarantee_check['surplus']:,}")
else:
    print(f"Guarantee shortfall: ${guarantee_check['shortfall']:,}")

# Calculate interest on underpayments
print(f"\nINTEREST CALCULATIONS:")
print("(10% simple interest from payment due date to 12/31/2025)")

total_interest = 0
for q in quarterly_details:
    if q["underpayment"] > 0:
        # Payment due 30 days after quarter end
        if q["quarter"] == "Q1 2025":
            due_date = "04/30/2025"
        elif q["quarter"] == "Q2 2025":
            due_date = "07/30/2025"
        elif q["quarter"] == "Q3 2025":
            due_date = "10/30/2025"
        elif q["quarter"] == "Q4 2025":
            due_date = "01/30/2026"
        
        # Calculate interest to 12/31/2025 (except Q4 which would be to actual due date)
        if q["quarter"] == "Q4 2025":
            to_date = "01/30/2026"  # Q4 payment not yet due as of 12/31/2025
            interest = 0  # No interest yet as payment not due
        else:
            to_date = "12/31/2025"
            interest = compute_interest(q["underpayment"], interest_rate, due_date, to_date)
        
        total_interest += interest
        
        print(f"{q['quarter']}: ${q['underpayment']:,} @ 10% from {due_date} to {to_date} = ${interest:,}")

print(f"\nTotal Interest: ${total_interest:,}")

# Total damages
total_damages = total_underpayment + total_interest
print(f"\nTOTAL DAMAGES:")
print(f"Unpaid Royalties: ${total_underpayment:,}")
print(f"Interest: ${total_interest:,}")
print(f"TOTAL: ${total_damages:,}")

# Material breach analysis
print(f"\nMATERIAL BREACH ANALYSIS:")
underpayment_percentage = (total_underpayment / total_owed) * 100
print(f"Underpayment as % of total owed: {underpayment_percentage:.1f}%")
print(f"Underpayment amount: ${total_underpayment:,}")

if underpayment_percentage > 10 or total_underpayment > 100_000:
    breach_type = "MATERIAL BREACH"
else:
    breach_type = "Minor breach"

print(f"Breach characterization: {breach_type}")
EOF

