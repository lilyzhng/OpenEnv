#!/usr/bin/env python3
"""Write a clean, professional memo with properly rounded numbers"""

import sys
sys.path.insert(0, "tools")
from royalty_calc import compute_royalty, compute_interest

# Case data
quarters = [
    {"quarter": "Q1 2025", "net_revenue": 5_500_000, "paid": 350_000, "due_date": "04/30/2025"},
    {"quarter": "Q2 2025", "net_revenue": 6_200_000, "paid": 380_000, "due_date": "07/30/2025"},
    {"quarter": "Q3 2025", "net_revenue": 7_100_000, "paid": 400_000, "due_date": "10/30/2025"},
    {"quarter": "Q4 2025", "net_revenue": 7_800_000, "paid": 420_000, "due_date": "01/30/2026"},
]

royalty_rate = 0.08
interest_rate = 0.10
analysis_date = "12/31/2025"

# Calculate all values
quarterly_data = []
total_owed = 0
total_paid = 0
total_shortfall = 0
total_interest = 0

for q in quarters:
    owed = round(compute_royalty(q["net_revenue"], royalty_rate))
    shortfall = owed - q["paid"]
    
    if q["quarter"] == "Q4 2025":
        interest = 0
    else:
        interest = compute_interest(shortfall, interest_rate, q["due_date"], analysis_date)
    
    quarterly_data.append({
        "quarter": q["quarter"],
        "revenue": q["net_revenue"],
        "owed": owed,
        "paid": q["paid"],
        "shortfall": shortfall,
        "interest": round(interest),
        "due_date": q["due_date"]
    })
    
    total_owed += owed
    total_paid += q["paid"]
    total_shortfall += shortfall
    total_interest += interest

total_interest = round(total_interest)
total_damages = total_shortfall + total_interest

# Write clean memo
with open("memo.txt", "w") as f:
    f.write("LEGAL MEMORANDUM\n")
    f.write("TO: Client\n")
    f.write("FROM: Litigation Analyst\n")
    f.write("RE: TechLoom Inc. v. DataForge Corp. — Royalty Dispute Analysis\n")
    f.write("DATE: Analysis as of December 31, 2025\n")
    f.write("=" * 70 + "\n\n")
    
    f.write("EXECUTIVE SUMMARY\n")
    f.write("-" * 17 + "\n")
    f.write(f"DataForge systematically underpaid royalties by ${total_shortfall:,} in 2025.\n")
    f.write(f"Total damages including interest: ${total_damages:,}.\n")
    f.write("This constitutes a material breach of the license agreement.\n\n")
    
    f.write("ROYALTY CALCULATIONS\n")
    f.write("-" * 20 + "\n")
    for qd in quarterly_data:
        f.write(f"{qd['quarter']}: Revenue ${qd['revenue']:,} x 8% = ${qd['owed']:,} owed\n")
        f.write(f"           Paid ${qd['paid']:,}, Shortfall ${qd['shortfall']:,}\n")
    f.write(f"\nTotal Unpaid Royalties: ${total_shortfall:,}\n\n")
    
    f.write("INTEREST CALCULATIONS\n")
    f.write("-" * 21 + "\n")
    f.write("10% simple interest from payment due dates to December 31, 2025:\n")
    for qd in quarterly_data:
        if qd["interest"] > 0:
            f.write(f"{qd['quarter']}: ${qd['shortfall']:,} from {qd['due_date']} = ${qd['interest']:,}\n")
        else:
            f.write(f"{qd['quarter']}: ${qd['shortfall']:,} (payment not yet due) = $0\n")
    f.write(f"\nTotal Interest: ${total_interest:,}\n\n")
    
    f.write("TOTAL DAMAGES\n")
    f.write("-" * 13 + "\n")
    f.write(f"Unpaid Royalties: ${total_shortfall:,}\n")
    f.write(f"Accrued Interest: ${total_interest:,}\n")
    f.write(f"TOTAL DAMAGES: ${total_damages:,}\n\n")
    
    underpayment_pct = (total_shortfall / total_owed) * 100
    f.write("BREACH CHARACTERIZATION\n")
    f.write("-" * 23 + "\n")
    f.write("Type: MATERIAL BREACH\n")
    f.write(f"Underpayment: {underpayment_pct:.1f}% of total royalties owed\n")
    f.write("Pattern: Systematic underpayment across all four quarters\n")
    f.write("Amount: $578,000 substantially exceeds materiality threshold\n\n")
    
    f.write("RECOMMENDED REMEDIES\n")
    f.write("-" * 20 + "\n")
    f.write(f"1. Monetary damages: ${total_damages:,}\n")
    f.write("2. Declaration of material breach\n")
    f.write("3. Demand immediate payment of all outstanding amounts\n")
    f.write("4. Enhanced audit rights and quarterly compliance reporting\n")
    f.write("5. Preserve termination rights after 60-day cure period\n")

print("Clean memo written to memo.txt")
EOF

