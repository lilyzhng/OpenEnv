    {"quarter": "Q1 2025", "end_date": "03/31/2025", "net_revenue": 5_500_000, "paid": 350_000, "due_date": "04/30/2025"},
    {"quarter": "Q2 2025", "end_date": "06/30/2025", "net_revenue": 6_200_000, "paid": 380_000, "due_date": "07/30/2025"},
    {"quarter": "Q3 2025", "end_date": "09/30/2025", "net_revenue": 7_100_000, "paid": 400_000, "due_date": "10/30/2025"},
    {"quarter": "Q4 2025", "end_date": "12/31/2025", "net_revenue": 7_800_000, "paid": 420_000, "due_date": "01/30/2026"},
]

# Contract terms
royalty_rate = 0.08  # 8%
minimum_annual_guarantee = 1_200_000
interest_rate = 0.10  # 10% per annum
analysis_date = "12/31/2025"

