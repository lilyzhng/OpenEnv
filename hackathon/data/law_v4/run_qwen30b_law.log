# Final royalty and damages analysis for TechLoom v DataForge
# Using the tools/royalty_calc.py for accurate calculations

import sys
sys.path.insert(0, "tools")
from royalty_calc import compute_royalty, compute_interest

# Quarterly data
quarters = [
    {'quarter': 'Q1 2025', 'end_date': '03/31/2025', 'revenue': 5500000, 'paid': 350000},
    {'quarter': 'Q2 2025', 'end_date': '06/30/2025', 'revenue': 6200000, 'paid': 380000},
    {'quarter': 'Q3 2025', 'end_date': '09/30/2025', 'revenue': 7100000, 'paid': 400000},
    {'quarter': 'Q4 2025', 'end_date': '12/31/2025', 'revenue': 7800000, 'paid': 420000}
]

# Royalty rate and minimum guarantee
royalty_rate = 0.08
min_guarantee = 1200000

# Calculate royalties owed and underpayments
results = []
total_underpaid = 0
total_interest = 0

for q in quarters:
    owed = compute_royalty(q['revenue'], royalty_rate)
    paid = q['paid']
    underpaid = max(0, owed - paid)
    
    # Calculate interest (10% simple annual interest from quarter end)
    # Interest period: 1 year from quarter end to current date (assuming 12/31/2025)
    interest = compute_interest(underpaid, 0.10, q['end_date'], "12/31/2025")
    
    total_underpaid += underpaid
    total_interest += interest
    
    results.append({
        'quarter': q['quarter'],
        'revenue': q['revenue'],
        'owed': owed,
        'paid': paid,
        'underpaid': underpaid,
        'interest': interest
    })

# Calculate total damages
total_owed = sum(r['owed'] for r in results)
total_paid = sum(r['paid'] for r in results)
total_damages = total_underpaid + total_interest

# Write memo
with open('memo.txt', 'w') as f:
    f.write('TECHLOOM INC. V. DATAFORGE CORP.\n')
    f.write('LEGAL MEMORANDUM\n')
    f.write('=' * 40 + '\n\n')
    
    f.write('1. ROYALTY CALCULATIONS\n')
    f.write('Quarter | Revenue | Owed | Paid | Underpaid | Interest\n')
    f.write('--------|---------|------|------|-----------|---------\n')
    
    for r in results:
        f.write(f'{r["quarter"]:<7} | ${r["revenue"]:,} | ${r["owed"]:.0f} | ${r["paid"]:.0f} | ${r["underpaid"]:.0f} | ${r["interest"]:.0f}\n')
    
    f.write(f'\nTotal Underpaid: ${total_underpaid:,.0f}\n')
    f.write(f'Total Interest: ${total_interest:,.0f}\n')
    f.write(f'Total Damages: ${total_damages:,.0f}\n\n')
    
    f.write('2. BREACH CHARACTERIZATION\n')
    f.write('DataForge has systematically underpaid royalties throughout 2025.\n')
    f.write('Each quarter showed underpayment of at least $100,000.\n')
    f.write('This constitutes a material breach of the license agreement.\n\n')
    
    f.write('3. RECOMMENDED REMEDIES\n')
    f.write('- Payment of total damages: $%s\n' % format(total_damages, ',.0f'))
    f.write('- Declaration of material breach\n')
    f.write('- Termination of license agreement\n')
    f.write('- Additional attorney fees and costs\n')
EOF

