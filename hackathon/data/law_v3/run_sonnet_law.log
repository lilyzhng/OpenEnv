import sys
sys.path.insert(0, "tools")
from royalty_calc import compute_royalty, compute_interest, check_minimum_guarantee

# Case data from techloom_v_dataforge.md
quarters = [
    {"quarter": "Q1 2025", "end_date": "03/31/2025", "net_revenue": 5_500_000, "paid": 350_000},
    {"quarter": "Q2 2025", "end_date": "06/30/2025", "net_revenue": 6_200_000, "paid": 380_000},
    {"quarter": "Q3 2025", "end_date": "09/30/2025", "net_revenue": 7_100_000, "paid": 400_000},
    {"quarter": "Q4 2025", "end_date": "12/31/2025", "net_revenue": 7_800_000, "paid": 420_000},
]

# Contract terms
royalty_rate = 0.08  # 8%
minimum_annual_guarantee = 1_200_000
interest_rate = 0.10  # 10% per annum simple interest
payment_due_days = 30  # within 30 days of quarter end

print("=== TECHLOOM V. DATAFORGE ROYALTY ANALYSIS ===\n")

# 1. Calculate royalties owed vs paid per quarter
print("1. QUARTERLY ROYALTY CALCULATIONS:")
print("-" * 50)

total_revenue = 0
total_owed = 0
total_paid = 0
quarterly_details = []

for q in quarters:
    revenue = q["net_revenue"]
    paid = q["paid"]
    owed = compute_royalty(revenue, royalty_rate)
    underpayment = owed - paid
    
    total_revenue += revenue
    total_owed += owed
    total_paid += paid
    
    quarterly_details.append({
        "quarter": q["quarter"],
        "end_date": q["end_date"],
        "revenue": revenue,
        "owed": owed,
        "paid": paid,
        "underpayment": underpayment
    })
    
    print(f"{q['quarter']}:")
    print(f"  Net Revenue: ${revenue:,}")
    print(f"  Royalty Owed (8%): ${owed:,.0f}")
    print(f"  Royalty Paid: ${paid:,}")
    print(f"  Underpayment: ${underpayment:,.0f}")
    print()

print(f"ANNUAL TOTALS:")
print(f"  Total Net Revenue: ${total_revenue:,}")
print(f"  Total Royalty Owed: ${total_owed:,.0f}")
print(f"  Total Royalty Paid: ${total_paid:,}")
print(f"  Total Underpayment: ${total_owed - total_paid:,.0f}")
print()

# 2. Interest calculations on underpayments
print("2. INTEREST CALCULATIONS:")
print("-" * 50)

# Payment due dates (30 days after quarter end)
due_dates = {
    "Q1 2025": "04/30/2025",
    "Q2 2025": "07/30/2025", 
    "Q3 2025": "10/30/2025",
    "Q4 2025": "01/30/2026"  # 30 days after 12/31/2025
}

# Calculate interest from due date to 12/31/2025 (end of dispute period)
# For Q4, calculate to a reasonable assessment date
assessment_date = "12/31/2025"
total_interest = 0

for detail in quarterly_details:
    quarter = detail["quarter"]
    underpayment = detail["underpayment"]
    
    if underpayment > 0:
        due_date = due_dates[quarter]
        
        # For Q4, use a later assessment date since due date is in 2026
        if quarter == "Q4 2025":
            # Interest would accrue from when payment was actually due
            # Using end of year for analysis purposes
            interest = 0  # No interest yet as due date hasn't passed by end of 2025
        else:
            interest = compute_interest(underpayment, interest_rate, due_date, assessment_date)
        
        total_interest += interest
        
        print(f"{quarter}:")
        print(f"  Underpayment: ${underpayment:,.0f}")
        print(f"  Due Date: {due_date}")
        print(f"  Interest (to {assessment_date}): ${interest:,.0f}")
        print()

print(f"Total Interest (through {assessment_date}): ${total_interest:,.0f}")
print()

# 3. Check minimum annual guarantee
print("3. MINIMUM ANNUAL GUARANTEE ANALYSIS:")
print("-" * 50)

guarantee_check = check_minimum_guarantee(total_owed, minimum_annual_guarantee)
print(f"Minimum Annual Guarantee: ${minimum_annual_guarantee:,}")
print(f"Total Royalties Owed: ${total_owed:,.0f}")

if guarantee_check["exceeded"]:
    print(f"✓ Minimum guarantee exceeded by: ${guarantee_check['surplus']:,.0f}")
else:
    print(f"✗ Minimum guarantee shortfall: ${guarantee_check['shortfall']:,.0f}")
print()

# 4. Total damages computation
print("4. TOTAL DAMAGES COMPUTATION:")
print("-" * 50)

total_unpaid_royalties = total_owed - total_paid
total_damages = total_unpaid_royalties + total_interest

print(f"Unpaid Royalties: ${total_unpaid_royalties:,.0f}")
print(f"Interest on Late Payments: ${total_interest:,.0f}")
print(f"TOTAL DAMAGES: ${total_damages:,.0f}")
print()

# 5. Breach analysis
print("5. BREACH CHARACTERIZATION:")
print("-" * 50)

underpayment_percentage = (total_unpaid_royalties / total_owed) * 100
print(f"Underpayment as % of total owed: {underpayment_percentage:.1f}%")

# Analyze pattern of underpayment
consistent_underpayment = all(detail["underpayment"] > 0 for detail in quarterly_details)
print(f"Consistent underpayment across all quarters: {consistent_underpayment}")

if underpayment_percentage > 10 and consistent_underpayment:
    breach_type = "MATERIAL BREACH"
    print(f"Conclusion: {breach_type}")
    print("- Systematic underpayment across all quarters")
    print(f"- Significant underpayment ({underpayment_percentage:.1f}% of total owed)")
    print("- Pattern suggests intentional conduct")
else:
    breach_type = "MINOR BREACH"
    print(f"Conclusion: {breach_type}")

print()

# Summary for memo
print("6. SUMMARY FOR LEGAL MEMO:")
print("-" * 50)
print(f"Total Damages Sought: ${total_damages:,.0f}")
print(f"Breach Classification: {breach_type}")
print("Recommended Remedies:")
print("- Payment of unpaid royalties")
print("- Payment of accrued interest")
if breach_type == "MATERIAL BREACH":
    print("- Consider termination of license agreement")
    print("- Demand immediate cure within 60-day period per contract")
print("- Audit of DataForge's books to verify revenue figures")
EOF

