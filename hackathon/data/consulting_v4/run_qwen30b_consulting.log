import re

# Read the market data file
with open('data/latam_market.md', 'r') as f:
    content = f.read()

# Extract key numbers using regex
total_it_spending = re.search(r'Total IT Spending.*?(\d+\.\d+)', content).group(1)
sas_share = re.search(r'B2B SaaS share.*?(\d+)%', content).group(1)
scm_share = re.search(r'SCM share.*?(\d+)%', content).group(1)
midmarket_share = re.search(r'mid-market companies.*?(\d+)%', content).group(1)

print(f'Total IT Spending: {total_it_spending} billion')
print(f'SaaS Share: {sas_share}%')
print(f'SCM Share: {scm_share}%')
print(f'Mid-market Share: {midmarket_share}%')

# Convert to numbers
total_it = float(total_it_spending)
sas_percent = float(sas_share) / 100
scm_percent = float(scm_share) / 100
midmarket_percent = float(midmarket_share) / 100

# Calculate TAM, SAM, SOM
tam = total_it * sas_percent
sam = tam * scm_percent
som = sam * midmarket_percent

print(f'TAM: ${tam:.1f} billion')
print(f'SAM: ${sam:.1f} billion')
print(f'SOM: ${som:.1f} billion')
"

