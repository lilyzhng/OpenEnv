import math

# Market calculations
tam = 85.0 * 0.18  # $15.3 billion
sam = tam * 0.12   # $1.836 billion
som = sam * 0.45   # $0.8262 billion

# Financials
acv = 48000
cac = 12000
lifespan = 3.0
margin = 0.72

arr_per_customer = acv
clv = arr_per_customer * lifespan
profit_per_customer = (arr_per_customer * margin) - cac

# Penetration targets
penetration_1y = 0.02
penetration_3y = 0.05
penetration_5y = 0.08

revenue_1y = som * penetration_1y
