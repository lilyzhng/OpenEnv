npv_20 = round(xnpv(0.20, dates, cash_flows), 1)

# Required Sale Value for target IRRs
def required_sale_value(target_irr):
    cfs = cash_flows[:-1] + [0.0]
    def f(sale):
        cfs[-1] = sale
        return xirr(dates, cfs) - target_irr
    low, high = 0, 100
    for _ in range(100):
        mid = (low + high) / 2
        cfs[-1] = mid
        if f(mid) > 0:
            high = mid
        else:
            low = mid
    return round(mid, 1)

sale_15 = required_sale_value(0.15)
sale_20 = required_sale_value(0.20)
sale_25 = required_sale_value(0.25)

# Required unit profit price for target IRRs
def required_unit_profit(target_irr):
    units = [50000, 55000, 60000, 65000, 70000, 75000, 80000, 85000]
    maintenance = -10.0
    sale = cash_flows[-1]
    def f(unit_profit):
        cfs = [cash_flows[0]]
        for u in units:
            cfs.append(u * unit_profit / 1e6)
        cfs.insert(5, maintenance)
        cfs.append(sale)
        return xirr(dates, cfs) - target_irr
    low, high = 50, 300
    for _ in range(100):
        mid = (low + high) / 2
        if f(mid) > 0:
            high = mid
        else:
            low = mid
    return round(mid, 2)

unit_15 = required_unit_profit(0.15)
unit_20 = required_unit_profit(0.20)
unit_25 = required_unit_profit(0.25)

with open("analysis.txt", "w") as f:
    f.write(f"KatNip Co. — Analysis Results\n")
    f.write(f"IRR: {irr*100:.1f}%\n")
    f.write(f"MOIC: {moic}x\n")
    f.write(f"NPV at 10%: ${npv_10}MM\n")
    f.write(f"NPV at 15%: ${npv_15}MM\n")
    f.write(f"NPV at 20%: ${npv_20}MM\n")
    f.write(f"Required Sale Value for 15% IRR: ${sale_15}MM\n")
    f.write(f"Required Sale Value for 20% IRR: ${sale_20}MM\n")
    f.write(f"Required Sale Value for 25% IRR: ${sale_25}MM\n")
    f.write(f"Required Unit Profit Price for 15% IRR: ${unit_15}\n")
    f.write(f"Required Unit Profit Price for 20% IRR: ${unit_20}\n")
    f.write(f"Required Unit Profit Price for 25% IRR: ${unit_25}\n")
EOF

