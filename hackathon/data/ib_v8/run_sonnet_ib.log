import sys
sys.path.insert(0, "tools")
from xirr_tool import xirr, xnpv
from datetime import datetime

# Cash flow data from the financial table
dates = [
    "03/03/2024",  # Initial capex
    "12/31/2024",  # Period 1
    "06/30/2025",  # Period 2
    "12/31/2025",  # Period 3
    "06/30/2026",  # Period 4
    "08/12/2026",  # Maintenance
    "12/31/2026",  # Period 5
    "06/30/2027",  # Period 6
    "12/31/2027",  # Period 7
    "06/30/2028",  # Period 8
    "12/31/2028"   # Sale value
]

cash_flows = [
    -50.0,  # Initial capex
    7.5,    # Period 1
    8.25,   # Period 2
    9.0,    # Period 3
    9.75,   # Period 4
    -10.0,  # Maintenance
    10.5,   # Period 5
    11.25,  # Period 6
    12.0,   # Period 7
    12.75,  # Period 8
    10.0    # Sale value
]

print("KatNip Co. Financial Analysis")
print("=" * 40)

# 1. Calculate IRR and MOIC
irr = xirr(dates, cash_flows)
print(f"IRR: {irr*100:.1f}%")

# MOIC = Total cash inflows / Total cash outflows
total_inflows = sum(cf for cf in cash_flows if cf > 0)
total_outflows = abs(sum(cf for cf in cash_flows if cf < 0))
moic = total_inflows / total_outflows
print(f"MOIC: {moic:.1f}x")

# 2. Calculate NPV at different discount rates
npv_10 = xnpv(0.10, dates, cash_flows)
npv_15 = xnpv(0.15, dates, cash_flows)
npv_20 = xnpv(0.20, dates, cash_flows)

print(f"NPV at 10%: ${npv_10:.1f}M")
print(f"NPV at 15%: ${npv_15:.1f}M")
print(f"NPV at 20%: ${npv_20:.1f}M")

# 3. Required Sale Value to achieve target IRRs
def find_required_sale_value(target_irr):
    """Find the sale value needed to achieve target IRR"""
    # Binary search for the required sale value
    low, high = 0, 200  # Search range in millions
    tolerance = 0.01
    
    for _ in range(100):  # Max iterations
        mid = (low + high) / 2
        test_cash_flows = cash_flows[:-1] + [mid]  # Replace last cash flow (sale value)
        
        try:
            test_irr = xirr(dates, test_cash_flows)
            if abs(test_irr - target_irr) < tolerance / 100:
                return mid
            elif test_irr < target_irr:
                low = mid
            else:
                high = mid
        except:
            low = mid
    
    return mid

sale_15 = find_required_sale_value(0.15)
sale_20 = find_required_sale_value(0.20)
sale_25 = find_required_sale_value(0.25)

print(f"Required Sale Value for 15% IRR: ${sale_15:.1f}M")
print(f"Required Sale Value for 20% IRR: ${sale_20:.1f}M")
print(f"Required Sale Value for 25% IRR: ${sale_25:.1f}M")

# 4. Required Unit Profit Price to achieve target IRRs
def find_required_unit_price(target_irr):
    """Find the unit profit price needed to achieve target IRR"""
    # Units sold per period: 50k, 55k, 60k, 65k, 70k, 75k, 80k, 85k
    units = [50000, 55000, 60000, 65000, 70000, 75000, 80000, 85000]
    
    # Binary search for the required unit price
    low, high = 0, 500  # Search range in dollars
    tolerance = 0.01
    
    for _ in range(100):  # Max iterations
        mid = (low + high) / 2
        
        # Calculate new cash flows with this unit price
        new_cash_flows = [cash_flows[0]]  # Initial capex
        for i, unit_count in enumerate(units):
            revenue = unit_count * mid / 1000000  # Convert to millions
            new_cash_flows.append(revenue)
        
        # Add maintenance and sale value
        new_cash_flows.insert(6, cash_flows[5])  # Maintenance at position 6
        new_cash_flows.append(cash_flows[-1])    # Sale value
        
        # Adjust dates for maintenance insertion
        test_dates = dates.copy()
        
        try:
            test_irr = xirr(test_dates, new_cash_flows)
            if abs(test_irr - target_irr) < tolerance / 100:
                return mid
            elif test_irr < target_irr:
                low = mid
            else:
                high = mid
        except:
            low = mid
    
    return mid

price_15 = find_required_unit_price(0.15)
