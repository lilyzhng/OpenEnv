import sys
sys.path.insert(0, "tools")
from xirr_tool import xirr, xnpv

# Verify cash flow data matches the table exactly
print("Verifying KatNip Co. cash flows:")
print("Date\t\tCash Flow")
print("-" * 30)

dates = [
    "03/03/2024",  # Initial capex
    "12/31/2024",  # Period 1: 50,000 units * $150 = $7.5M
    "06/30/2025",  # Period 2: 55,000 units * $150 = $8.25M
    "12/31/2025",  # Period 3: 60,000 units * $150 = $9.0M
    "06/30/2026",  # Period 4: 65,000 units * $150 = $9.75M
    "08/12/2026",  # Maintenance: -$10.0M
    "12/31/2026",  # Period 5: 70,000 units * $150 = $10.5M
    "06/30/2027",  # Period 6: 75,000 units * $150 = $11.25M
    "12/31/2027",  # Period 7: 80,000 units * $150 = $12.0M
    "06/30/2028",  # Period 8: 85,000 units * $150 = $12.75M
    "12/31/2028"   # Sale value: $10.0M
]

cash_flows = [-50.0, 7.5, 8.25, 9.0, 9.75, -10.0, 10.5, 11.25, 12.0, 12.75, 10.0]

for date, cf in zip(dates, cash_flows):
    print(f"{date}\t${cf:.2f}M")

print(f"\nTotal outflows: ${sum(cf for cf in cash_flows if cf < 0):.1f}M")
print(f"Total inflows: ${sum(cf for cf in cash_flows if cf > 0):.1f}M")

# Recalculate key metrics
irr = xirr(dates, cash_flows)
total_inflows = sum(cf for cf in cash_flows if cf > 0)
total_outflows = abs(sum(cf for cf in cash_flows if cf < 0))
moic = total_inflows / total_outflows

print(f"\nIRR: {irr*100:.1f}%")
print(f"MOIC: {moic:.1f}x")

# NPVs
for rate in [0.10, 0.15, 0.20]:
    npv = xnpv(rate, dates, cash_flows)
    print(f"NPV at {rate*100:.0f}%: ${npv:.1f}M")
EOF

