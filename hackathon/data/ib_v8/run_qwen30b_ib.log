import json
import numpy as np
from scipy.optimize import brentq

# Read financial data
with open('/var/folders/zb/gv9h0w894b92wzw6hwsqc0pr0000gn/T/apex_bb_vf0h4l9w/data/katnip_financials.txt', 'r') as f:
    content = f.read()

# Extract cash flows
cash_flows = [-50.0, 7.5, 8.25, 9.0, 9.75, -10.0, 10.5, 11.25, 12.0, 12.75, 10.0]
dates = ['03/03/2024', '12/31/2024', '06/30/2025', '12/31/2025', '06/30/2026', '08/12/2026', '12/31/2026', '06/30/2027', '12/31/2027', '06/30/2028', '12/31/2028']

# Calculate IRR
def irr_function(rate):
    total = 0
    for i, cf in enumerate(cash_flows):
        if i == 0:
            total += cf
        else:
            # Calculate time difference in years
            from datetime import datetime
            date1 = datetime.strptime(dates[0], '%m/%d/%Y')
            date2 = datetime.strptime(dates[i], '%m/%d/%Y')
            years = (date2 - date1).days / 365.25
            total += cf / ((1 + rate) ** years)
    return total

# Find IRR
try:
    irr = brentq(irr_function, -0.99, 10.0)
except:
    irr = None

# Calculate NPV with 10% discount rate
def npv_function(rate):
    total = 0
    for i, cf in enumerate(cash_flows):
        if i == 0:
            total += cf
        else:
            from datetime import datetime
            date1 = datetime.strptime(dates[0], '%m/%d/%Y')
            date2 = datetime.strptime(dates[i], '%m/%d/%Y')
            years = (date2 - date1).days / 365.25
            total += cf / ((1 + rate) ** years)
    return total

npv_10 = npv_function(0.10)

# Calculate payback period
cumulative = 0
payback_period = None
for i, cf in enumerate(cash_flows):
    cumulative += cf
    if cumulative >= 0 and payback_period is None:
        # Interpolate for exact payback point
        if i > 0:
            prev_cum = cumulative - cf
            if prev_cum < 0:
                payback_period = (i-1) + abs(prev_cum) / cf
        else:
            payback_period = 0

# Calculate total revenue
total_revenue = sum([7.5, 8.25, 9.0, 9.75, 10.5, 11.25, 12.0, 12.75])
total_cost = 50.0  # Capex
net_profit = total_revenue - total_cost

# Write results to analysis.txt
with open('/var/folders/zb/gv9h0w894b92wzw6hwsqc0pr0000gn/T/apex_bb_vf0h4l9w/analysis.txt', 'w') as f:
    f.write('KatNip Co. Analysis\n')
    f.write('===================\n\n')
    f.write(f'IRR: {irr:.2%}\n')
    f.write(f'NPV (10% discount rate): ${npv_10:.2f}M\n')
    f.write(f'Payback Period: {payback_period:.2f} years\n')
    f.write(f'Total Revenue: ${total_revenue:.2f}M\n')
    f.write(f'Net Profit: ${net_profit:.2f}M\n')
    f.write(f'Initial Investment: ${total_cost:.2f}M\n')
    f.write(f'Cash Flows: {cash_flows}\n')
"

