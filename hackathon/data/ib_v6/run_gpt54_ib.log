from datetime import datetime

dates_str = [
    "03/03/2024",
    "12/31/2024",
    "06/30/2025",
    "12/31/2025",
    "06/30/2026",
    "08/12/2026",
    "12/31/2026",
    "06/30/2027",
    "12/31/2027",
    "06/30/2028",
    "12/31/2028",
]
dates = [datetime.strptime(d, "%m/%d/%Y") for d in dates_str]
cfs = [-50.0, 7.5, 8.25, 9.0, 9.75, -10.0, 10.5, 11.25, 12.0, 12.75, 10.0]

def xnpv(rate, cashflows, dates):
    t0 = dates[0]
    return sum(cf / ((1 + rate) ** ((d - t0).days / 365.0)) for cf, d in zip(cashflows, dates))

def xirr(cashflows, dates):
    lo, hi = -0.9999, 10.0
    flo, fhi = xnpv(lo, cashflows, dates), xnpv(hi, cashflows, dates)
    while flo * fhi > 0 and hi < 1e6:
        hi *= 2
        fhi = xnpv(hi, cashflows, dates)
    for _ in range(300):
        mid = (lo + hi) / 2
        fmid = xnpv(mid, cashflows, dates)
        if abs(fmid) < 1e-12:
            return mid
        if flo * fmid <= 0:
            hi, fhi = mid, fmid
        else:
            lo, flo = mid, fmid
    return (lo + hi) / 2

irr = xirr(cfs, dates)
moic = sum(cf for cf in cfs if cf > 0) / abs(sum(cf for cf in cfs if cf < 0))

npv10 = xnpv(0.10, cfs, dates)
npv15 = xnpv(0.15, cfs, dates)
npv20 = xnpv(0.20, cfs, dates)

sale_date = datetime.strptime("12/31/2028", "%m/%d/%Y")
sale_idx = dates.index(sale_date)

def required_sale_for_target_irr(target):
    base = cfs.copy()
    base[sale_idx] = 0.0
    t0 = dates[0]
    pv_others = sum(cf / ((1 + target) ** ((d - t0).days / 365.0)) for cf, d in zip(base, dates))
    years = (sale_date - t0).days / 365.0
    sale = -pv_others * ((1 + target) ** years)
    return sale

base_units = [0, 50000, 55000, 60000, 65000, 0, 70000, 75000, 80000, 85000, 0]
maint_idx = dates.index(datetime.strptime("08/12/2026", "%m/%d/%Y"))

def required_unit_profit(target):
    t0 = dates[0]
    pv_units = 0.0
    for units, d in zip(base_units, dates):
        if units:
            pv_units += units / ((1 + target) ** ((d - t0).days / 365.0))
    pv_fixed = (-50.0) + (-10.0) / ((1 + target) ** ((dates[maint_idx] - t0).days / 365.0)) + 10.0 / ((1 + target) ** ((sale_date - t0).days / 365.0))
    price_millions_per_unit = -pv_fixed / pv_units
    return price_millions_per_unit * 1_000_000

req_sale_15 = required_sale_for_target_irr(0.15)
req_sale_20 = required_sale_for_target_irr(0.20)
req_sale_25 = required_sale_for_target_irr(0.25)

req_price_15 = required_unit_profit(0.15)
req_price_20 = required_unit_profit(0.20)
req_price_25 = required_unit_profit(0.25)

with open("analysis.txt", "w") as f:
    f.write("KatNip Co. Analysis\n")
    f.write(f"IRR: {irr*100:.1f}%\n")
    f.write(f"MOIC: {moic:.1f}x\n")
    f.write(f"NPV @ 10%: ${npv10:.1f}MM\n")
    f.write(f"NPV @ 15%: ${npv15:.1f}MM\n")
    f.write(f"NPV @ 20%: ${npv20:.1f}MM\n")
    f.write(f"Required Sale Value for 15% IRR: ${req_sale_15:.1f}MM\n")
    f.write(f"Required Sale Value for 20% IRR: ${req_sale_20:.1f}MM\n")
    f.write(f"Required Sale Value for 25% IRR: ${req_sale_25:.1f}MM\n")
    f.write(f"Required Unit Profit Price for 15% IRR: ${req_price_15:.2f}\n")
    f.write(f"Required Unit Profit Price for 20% IRR: ${req_price_20:.2f}\n")
    f.write(f"Required Unit Profit Price for 25% IRR: ${req_price_25:.2f}\n")
print(open("analysis.txt").read())
PY

