import sys
sys.path.insert(0, "tools")
from xirr_tool import xirr, xnpv

# Cash flows and dates
dates = [
    "03/03/2024",  # Initial capex
    "12/31/2024",  # Period 1
    "06/30/2025",  # Period 2
    "12/31/2025",  # Period 3
    "06/30/2026",  # Period 4
    "08/12/2026",  # Maintenance expense
    "12/31/2026",  # Period 5
    "06/30/2027",  # Period 6
    "12/31/2027",  # Period 7
    "06/30/2028",  # Period 8
    "12/31/2028"   # Sale value
]

cash_flows = [
    -50.0,  # Initial capex
    7.5,    # Period 1
    8.25,   # Period 2
    9.0,    # Period 3
    9.75,   # Period 4
    -10.0,  # Maintenance expense
    10.5,   # Period 5
    11.25,  # Period 6
    12.0,   # Period 7
    12.75,  # Period 8
    10.0    # Sale value
]

# Calculate payback period
cumulative_cf = 0
payback_period = None
for i, cf in enumerate(cash_flows):
    cumulative_cf += cf
    if cumulative_cf > 0 and payback_period is None:
        # Linear interpolation for exact payback
        if i > 0:
            prev_cumulative = cumulative_cf - cf
            fraction = -prev_cumulative / cf
            payback_period = i - 1 + fraction
        else:
            payback_period = i
        break

print(f"Payback Period: {payback_period:.1f} periods")

# Calculate break-even analysis
total_investment = 50.0 + 10.0  # Initial + maintenance
total_positive_cf = sum([cf for cf in cash_flows if cf > 0])
print(f"Total Investment: ${total_investment:.1f}MM")
print(f"Total Returns: ${total_positive_cf:.1f}MM")
print(f"Net Profit: ${total_positive_cf - total_investment:.1f}MM")
EOF

