import sys
sys.path.insert(0, "tools")
from xirr_tool import xirr, xnpv
import json

# Load historical rates
with open('/var/folders/zb/gv9h0w894b92wzw6hwsqc0pr0000gn/T/apex_bb_s30c2nye/data/historical_rates.json', 'r') as f:
    rates = json.load(f)

# Calculate average rates
avg_10yr = sum(rates['10yr_treasury']) / len(rates['10yr_treasury'])
avg_fed = sum(rates['fed_funds']) / len(rates['fed_funds'])
avg_libor = sum(rates['libor_6m']) / len(rates['libor_6m'])

print(f"Risk-free rate (10yr Treasury): {avg_10yr:.1f}%")
print(f"Fed Funds rate: {avg_fed:.1f}%")
print(f"6M LIBOR: {avg_libor:.1f}%")

# Estimate WACC for KatNip
# Assuming equity risk premium of 6% and beta of 1.2 for a small manufacturing company
risk_free = avg_10yr / 100
equity_risk_premium = 0.06
beta = 1.2
cost_of_equity = risk_free + beta * equity_risk_premium

# Assuming cost of debt = LIBOR + spread (say 2%)
cost_of_debt = avg_libor / 100 + 0.02

# Assuming 70% equity, 30% debt, 25% tax rate
equity_weight = 0.7
debt_weight = 0.3
tax_rate = 0.25

wacc = equity_weight * cost_of_equity + debt_weight * cost_of_debt * (1 - tax_rate)

print(f"\nEstimated WACC Components:")
print(f"Cost of Equity: {cost_of_equity*100:.1f}%")
print(f"Cost of Debt (after-tax): {cost_of_debt*(1-tax_rate)*100:.1f}%")
print(f"WACC: {wacc*100:.1f}%")

# Calculate NPV at WACC
dates = [
    "03/03/2024", "12/31/2024", "06/30/2025", "12/31/2025", "06/30/2026",
    "08/12/2026", "12/31/2026", "06/30/2027", "12/31/2027", "06/30/2028", "12/31/2028"
]

cash_flows = [-50.0, 7.5, 8.25, 9.0, 9.75, -10.0, 10.5, 11.25, 12.0, 12.75, 10.0]

npv_at_wacc = xnpv(wacc, dates, cash_flows)
print(f"\nNPV at WACC ({wacc*100:.1f}%): ${npv_at_wacc:.1f}MM")
EOF

