# Load the financial data from katnip_financials.txt
# Based on the cash flow schedule provided

# Cash flows with dates (from the financial data)
dates = [
    "03/03/2024",  # Initial capex
    "12/31/2024",  # Period 1
    "06/30/2025",  # Period 2
    "12/31/2025",  # Period 3
    "06/30/2026",  # Period 4
    "08/12/2026",  # Maintenance expense
    "12/31/2026",  # Period 5
    "06/30/2027",  # Period 6
    "12/31/2027",  # Period 7
    "06/30/2028",  # Period 8
    "12/31/2028"   # Sale value
]

cash_flows = [
    -50.0,  # Initial capex
    7.5,    # Period 1
    8.25,   # Period 2
    9.0,    # Period 3
    9.75,   # Period 4
    -10.0,  # Maintenance expense
    10.5,   # Period 5
    11.25,  # Period 6
    12.0,   # Period 7
    12.75,  # Period 8
    10.0    # Sale value
]

print("=== KatNip Co. Financial Analysis ===")
print()

# 1. Calculate IRR and MOIC
irr = xirr(dates, cash_flows)
print(f"1. IRR: {irr*100:.1f}%")

# Calculate MOIC (Multiple of Invested Capital)
total_invested = 50.0 + 10.0  # Initial capex + maintenance
total_returns = sum([cf for cf in cash_flows if cf > 0])
moic = total_returns / total_invested
print(f"   MOIC: {moic:.1f}x")
print()

# 2. Calculate NPV at different discount rates
discount_rates = [0.10, 0.15, 0.20]
print("2. NPV Analysis:")
for rate in discount_rates:
    npv = xnpv(rate, dates, cash_flows)
    print(f"   NPV at {rate*100:.0f}%: ${npv:.1f}MM")
print()

# 3. Required Sale Value to achieve target IRRs
print("3. Required Sale Value for Target IRRs:")
target_irrs = [0.15, 0.20, 0.25]

for target_irr in target_irrs:
    # Binary search for required sale value
    low, high = 0, 100
    tolerance = 0.01
    
    for _ in range(100):  # Max iterations
        mid = (low + high) / 2
        test_cash_flows = cash_flows[:-1] + [mid]  # Replace last cash flow (sale value)
        
        try:
            test_irr = xirr(dates, test_cash_flows)
            if abs(test_irr - target_irr) < tolerance / 100:
                break
            elif test_irr < target_irr:
                low = mid
            else:
                high = mid
        except:
            low = mid
    
    print(f"   Sale Value for {target_irr*100:.0f}% IRR: ${mid:.1f}MM")
print()

# 4. Required Unit Profit Price to achieve target IRRs
print("4. Required Unit Profit Price for Target IRRs:")

# Current unit profit is $150, let's calculate what's needed for target IRRs
current_unit_profit = 150
units_schedule = [50000, 55000, 60000, 65000, 70000, 75000, 80000, 85000]

for target_irr in target_irrs:
    # Binary search for required unit profit price
    low, high = 50, 500
    tolerance = 0.01
    
    for _ in range(100):  # Max iterations
        mid_price = (low + high) / 2
        
        # Calculate new cash flows with adjusted unit profit price
        price_ratio = mid_price / current_unit_profit
        new_cash_flows = [
            -50.0,  # Initial capex (unchanged)
            7.5 * price_ratio,    # Period 1
            8.25 * price_ratio,   # Period 2
            9.0 * price_ratio,    # Period 3
            9.75 * price_ratio,   # Period 4
            -10.0,  # Maintenance expense (unchanged)
            10.5 * price_ratio,   # Period 5
            11.25 * price_ratio,  # Period 6
            12.0 * price_ratio,   # Period 7
            12.75 * price_ratio,  # Period 8
            10.0    # Sale value (unchanged)
        ]
        
        try:
            test_irr = xirr(dates, new_cash_flows)
            if abs(test_irr - target_irr) < tolerance / 100:
                break
            elif test_irr < target_irr:
                low = mid_price
            else:
                high = mid_price
        except:
            low = mid_price
    
    print(f"   Unit Profit Price for {target_irr*100:.0f}% IRR: ${mid_price:.2f}")

