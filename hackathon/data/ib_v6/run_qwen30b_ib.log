import json
import numpy as np
from datetime import datetime

# Load financial data
with open('./data/katnip_financials.txt', 'r') as f:
    content = f.read()

# Extract cash flows from table
cash_flows = [-50.0, 7.5, 8.25, 9.0, 9.75, -10.0, 10.5, 11.25, 12.0, 12.75, 10.0]
dates = ['03/03/2024', '12/31/2024', '06/30/2025', '12/31/2025', '06/30/2026', '08/12/2026', '12/31/2026', '06/30/2027', '12/31/2027', '06/30/2028', '12/31/2028']

# Load historical rates
with open('./data/historical_rates.json', 'r') as f:
    rates = json.load(f)

# Calculate IRR using xirr_tool
import sys; sys.path.insert(0, 'tools')
from xirr_tool import xirr

irr = xirr(dates, cash_flows)
print(f'IRR: {irr*100:.1f}%')

# Calculate MOIC (Total Cash Inflows / Total Cash Outflows)
total_inflows = sum(cf for cf in cash_flows if cf > 0)
total_outflows = abs(sum(cf for cf in cash_flows if cf < 0))
moic = total_inflows / total_outflows
