<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Draw: HOURGLASS</title></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#e8dcc8;">
<svg id="art" viewBox="0 0 300 300" width="300" height="300" xmlns="http://www.w3.org/2000/svg"></svg>
<script src="https://unpkg.com/roughjs/bundled/rough.js"></script>
<script src="elements/triangle.js"></script>
<script src="elements/rectangle.js"></script>
<script src="elements/line.js"></script>
<script src="elements/circle.js"></script>
<script>
const INK = '#1a1a1a';
const svg = document.getElementById('art');
const rc = rough.svg(svg);
const opts = { stroke: INK, strokeWidth: 3.5, fill: 'none', roughness: 0.8 };

// Hourglass frame - outer rectangle
drawRectangle(rc, svg, 75, 50, 150, 200, opts);

// Top triangle (sand chamber) - pointing down
drawTriangle(rc, svg, 150, 120, 120, 'down', opts);

// Bottom triangle (sand chamber) - pointing up  
drawTriangle(rc, svg, 150, 180, 120, 'up', opts);

// Sand in bottom chamber - filled triangle
const sandOpts = { stroke: INK, strokeWidth: 2, fill: '#d4af37', fillStyle: 'solid', roughness: 0.8 };
drawTriangle(rc, svg, 150, 200, 80, 'up', sandOpts);

// Narrow connecting point in middle
drawLine(rc, svg, 140, 150, 160, 150, opts);

// Sand falling - small circles
const sandParticles = { stroke: INK, strokeWidth: 2, fill: '#d4af37', fillStyle: 'solid', roughness: 0.8 };
svg.appendChild(rc.circle(148, 140, 3, sandParticles));
svg.appendChild(rc.circle(152, 135, 3, sandParticles));
svg.appendChild(rc.circle(150, 160, 3, sandParticles));

</script>
</body>
</html>
EOF

