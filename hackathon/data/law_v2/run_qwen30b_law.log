import sys
sys.path.insert(0, 'tools')
from royalty_calc import compute_royalty, compute_interest, check_minimum_guarantee

# Quarterly data
quarters = [
    {'quarter': 'Q1 2025', 'end_date': '03/31/2025', 'revenue': 5_500_000, 'paid': 350_000},
    {'quarter': 'Q2 2025', 'end_date': '06/30/2025', 'revenue': 6_200_000, 'paid': 380_000},
    {'quarter': 'Q3 2025', 'end_date': '09/30/2025', 'revenue': 7_100_000, 'paid': 400_000},
    {'quarter': 'Q4 2025', 'end_date': '12/31/2025', 'revenue': 7_800_000, 'paid': 420_000},
]

# Calculate royalties and interest
total_owed = 0
total_paid = 0
total_interest = 0

results = []
for q in quarters:
    owed = compute_royalty(q['revenue'], 0.08)
    total_owed += owed
    total_paid += q['paid']
    shortfall = owed - q['paid']
    
    if shortfall > 0:
        # Calculate interest from quarter end to 12/31/2025
        interest = compute_interest(shortfall, 0.10, q['end_date'], '12/31/2025')
        total_interest += interest
        results.append({
            'quarter': q['quarter'],
            'revenue': q['revenue'],
            'owed': owed,
            'paid': q['paid'],
            'shortfall': shortfall,
            'interest': interest
        })
    else:
        results.append({
            'quarter': q['quarter'],
            'revenue': q['revenue'],
            'owed': owed,
            'paid': q['paid'],
            'shortfall': 0,
            'interest': 0
        })

# Check minimum guarantee
min_guarantee = 1_200_000
min_check = check_minimum_guarantee(total_owed, min_guarantee)

# Calculate total damages
total_damages = total_owed - total_paid + total_interest

print('TechLoom v. DataForge - Royalty Analysis')
print('=' * 50)
print()
print('Quarterly Breakdown:')
print('Quarter    | Revenue     | Owed      | Paid      | Shortfall | Interest')
print('-----------|-------------|-----------|-----------|-----------|---------')
for r in results:
    print(f\"{r['quarter']:10} | ${r['revenue']:>10,} | ${r['owed']:>9,.0f} | ${r['paid']:>9,.0f} | ${r['shortfall']:>9,.0f} | ${r['interest']:>7,.0f}\")

print()
print(f'Total Royalties Owed: ${total_owed:,.0f}')
print(f'Total Paid: ${total_paid:,.0f}')
print(f'Total Interest: ${total_interest:,.0f}')
print(f'Minimum Guarantee: ${min_guarantee:,.0f}')
print(f'Minimum Guarantee Met: {\"Yes\" if min_check[\"exceeded\"] else \"No\"}')
if not min_check[\"exceeded\"]:
    print(f'Minimum Shortfall: ${min_check[\"shortfall\"]:,.0f}')
print()
print(f'Total Damages: ${total_damages:,.0f}')
