<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Draw: HOURGLASS</title></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#e8dcc8;">
<svg id="art" viewBox="0 0 300 300" width="300" height="300" xmlns="http://www.w3.org/2000/svg"></svg>
<script src="https://unpkg.com/roughjs/bundled/rough.js"></script>
<script src="elements/triangle.js"></script>
<script src="elements/line.js"></script>
<script src="elements/rectangle.js"></script>
<script>
const INK = '#1a1a1a';
const svg = document.getElementById('art');
const rc = rough.svg(svg);
const opts = { stroke: INK, strokeWidth: 3.5, fill: 'none', roughness: 0.8 };

// Hourglass frame - top and bottom rectangles
drawRectangle(rc, svg, 100, 50, 100, 20, opts);
drawRectangle(rc, svg, 100, 230, 100, 20, opts);

// Hourglass sides - connecting lines from top to narrow middle
drawLine(rc, svg, 100, 70, 140, 150, opts);
drawLine(rc, svg, 200, 70, 160, 150, opts);

// Hourglass sides - connecting lines from narrow middle to bottom
drawLine(rc, svg, 140, 150, 100, 230, opts);
drawLine(rc, svg, 160, 150, 200, 230, opts);

// Sand in top section - triangular shape
drawTriangle(rc, svg, 150, 110, 80, 'down', {...opts, fill: '#d4af37', fillStyle: 'solid'});

// Sand in bottom section - smaller triangular shape
drawTriangle(rc, svg, 150, 210, 40, 'up', {...opts, fill: '#d4af37', fillStyle: 'solid'});

// Narrow stream of sand falling
drawLine(rc, svg, 150, 140, 150, 160, {...opts, strokeWidth: 2});

</script>
</body>
</html>
EOF

