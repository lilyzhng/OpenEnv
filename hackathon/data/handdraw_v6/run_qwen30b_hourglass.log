<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Hourglass</title></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#e8dcc8;">
<svg id="art" viewBox="0 0 300 300" width="300" height="300" xmlns="http://www.w3.org/2000/svg"></svg>
<script src="https://unpkg.com/roughjs/bundled/rough.js"></script>
<script src="elements/triangle.js"></script>
<script src="elements/circle.js"></script>
<script src="elements/rectangle.js"></script>
<script src="elements/line.js"></script>
<script src="elements/arc.js"></script>
<script>
const INK = '#1a1a1a';
const svg = document.getElementById('art');
const rc = rough.svg(svg);
const opts = { stroke: INK, strokeWidth: 3.5, fill: 'none', roughness: 0.8 };

// Hourglass = two triangles (top and bottom) with a narrow neck
// Top triangle
drawTriangle(rc, svg, 150, 100, 120, 'up', opts);

// Bottom triangle
drawTriangle(rc, svg, 150, 200, 120, 'down', opts);

// Neck connecting the two triangles
drawRectangle(rc, svg, 130, 140, 40, 20, opts);

// Sand particles falling from top
drawCircle(rc, svg, 150, 110, 8, opts);
drawCircle(rc, svg, 140, 120, 6, opts);
drawCircle(rc, svg, 160, 125, 5, opts);
drawCircle(rc, svg, 135, 130, 7, opts);

// Sand particles in the neck
drawCircle(rc, svg, 145, 150, 5, opts);
drawCircle(rc, svg, 155, 155, 4, opts);

// Sand particles at the bottom
drawCircle(rc, svg, 150, 190, 6, opts);
drawCircle(rc, svg, 140, 185, 5, opts);
drawCircle(rc, svg, 160, 180, 7, opts);

// Decorative arcs for visual interest
drawArc(rc, svg, 100, 100, 200, 100, 50, 30, opts);
drawArc(rc, svg, 100, 200, 200, 200, 50, 30, opts);

</script>
</body>
</html>
EOF

