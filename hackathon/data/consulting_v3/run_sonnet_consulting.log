import sys
sys.path.insert(0, "tools")
from market_sizing import compute_tam, compute_sam, compute_som, compute_unit_economics

# Data from market brief
total_it_spend = 85_000  # $MM (Latin America total IT spending)
saas_share = 0.18  # B2B SaaS share of total IT spending
segment_share = 0.12  # SCM share of B2B SaaS market
target_share = 0.45  # Mid-market companies share of SCM market

# Market sizing
tam = compute_tam(total_it_spend, saas_share, segment_share)
sam = compute_sam(tam, target_share)

# SOM calculations for Year 1, 3, 5
som_y1 = compute_som(sam, penetration=0.02)  # Year 1: 2% of SAM
som_y3 = compute_som(sam, penetration=0.05)  # Year 3: 5% of SAM
som_y5 = compute_som(sam, penetration=0.08)  # Year 5: 8% of SAM

print(f"TAM: ${tam:,.1f}MM")
print(f"SAM: ${sam:,.1f}MM")
print(f"Year 1 SOM: ${som_y1:,.1f}MM")
print(f"Year 3 SOM: ${som_y3:,.1f}MM")
print(f"Year 5 SOM: ${som_y5:,.1f}MM")

# Unit economics
econ = compute_unit_economics(acv=48_000, cac=12_000, lifespan_years=3.0)
print(f"\nLTV: ${econ['ltv']:,.0f}")
print(f"LTV/CAC: {econ['ltv_cac_ratio']:.1f}x")
print(f"CAC Payback: {econ['cac_payback_months']:.1f} months")

# Country ranking analysis (from market data)
countries = [
    ("Brazil", 8.5, "45% IT spend share, high SaaS maturity"),
    ("Mexico", 8.0, "20% IT spend share, high SaaS maturity, high regulatory ease"),
