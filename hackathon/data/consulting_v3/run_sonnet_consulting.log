]

print(f"\nTop 3 Countries by Attractiveness:")
for i, (country, score, reason) in enumerate(countries, 1):
    print(f"{i}. {country} (Score: {score}) - {reason}")

# Entry mode recommendation
print(f"\nEntry Mode Analysis:")
print(f"NovaTech has $18MM cash, could fund $3-5MM expansion")
print(f"Joint Venture: $3-5MM investment, 6-9 months to revenue, medium control/risk")
print(f"Recommendation: Joint Venture - fits budget and risk profile")

