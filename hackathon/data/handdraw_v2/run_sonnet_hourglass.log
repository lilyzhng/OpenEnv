COMMAND: cat > hourglass.html << 'EOF'
<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Draw: HOURGLASS</title></head>
<body style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#e8dcc8;">
<svg id="art" viewBox="0 0 300 300" width="300" height="300" xmlns="http://www.w3.org/2000/svg"></svg>
<script src="https://unpkg.com/roughjs/bundled/rough.js"></script>
<script>
const INK = '#1a1a1a';
const WHITE = '#f0ebe0';

const svg = document.getElementById('art');
const rc = rough.svg(svg);

// Hourglass outline - two triangular sections
const outlineOpts = { stroke: INK, strokeWidth: 3.5, fill: 'none', roughness: 0.8 };

// Top triangle (sand container)
svg.appendChild(rc.polygon([[150, 80], [100, 150], [200, 150]], outlineOpts));

// Bottom triangle (sand container)  
svg.appendChild(rc.polygon([[150, 220], [102, 150], [198, 150]], outlineOpts));

// Hourglass frame - top and bottom rectangles
svg.appendChild(rc.rectangle(85, 65, 130, 18, outlineOpts));
svg.appendChild(rc.rectangle(87, 217, 126, 18, outlineOpts));

// Sand in top section - smaller triangle
const sandOpts = { stroke: INK, strokeWidth: 2.5, fill: INK, fillStyle: 'solid', roughness: 0.6 };
svg.appendChild(rc.polygon([[150, 95], [125, 135], [175, 135]], sandOpts));

// Sand pile in bottom section
svg.appendChild(rc.polygon([[150, 205], [115, 165], [185, 165]], sandOpts));

// Falling sand stream - thin line
const streamOpts = { stroke: INK, strokeWidth: 2, roughness: 0.9 };
svg.appendChild(rc.line(150, 135, 150, 165, streamOpts));

// Sand particles falling
const dotOpts = { stroke: INK, strokeWidth: 1.5, fill: INK, fillStyle: 'solid', roughness: 0.5 };
svg.appendChild(rc.circle(148, 145, 3, dotOpts));
svg.appendChild(rc.circle(152, 155, 2, dotOpts));
svg.appendChild(rc.circle(149, 160, 2, dotOpts));

</script>
</body>
</html>
EOF

